---
const { profile } = Astro.props;

const averageFromRatings = (ratings) => {
  const values = Object.values(ratings);
  return values.reduce((sum, value) => sum + value, 0) / values.length;
};

const totalReviews = profile.reviews.length;

const averageCoffee =
  totalReviews > 0
    ? (
        profile.reviews.reduce((sum, review) => sum + review.ratings.coffee, 0) /
        totalReviews
      ).toFixed(1)
    : null;
---

<html lang="sr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{profile.firstName} {profile.lastName}</title>
    <meta
      name="description"
      content={`${profile.firstName} ${profile.lastName} - profil i recenzije kafića`}
    />
  </head>

  <body>
    <main class="page">
      <div class="shape shape-top-left"></div>
      <div class="shape shape-top-right"></div>
      <div class="shape shape-bottom-left"></div>

      <div class="container">
        <section class="hero-card">
          <div class="avatar-wrap">
            <img
              src={profile.image}
              alt={`${profile.firstName} ${profile.lastName}`}
              class="avatar"
            />
          </div>

          <h1 class="name">
            <span>{profile.firstName}</span>
            <span>{profile.lastName}</span>
          </h1>

          <p class="pik">{profile.pik}</p>
        </section>

        <section class="info-card">
          <div class="info-item">
            <span class="label">Nick</span>
            <p class="value">{profile.nick}</p>
          </div>

          <div class="info-item">
            <span class="label">D.O.B.</span>
            <p class="value">{profile.dob}</p>
          </div>

          <div class="info-item">
            <span class="label">Fav. kafe</span>
            <p class="value">{profile.favoriteCafe}</p>
          </div>

          <div class="info-item">
            <span class="label">Life moto</span>
            <p class="value">{profile.lifeMotto}</p>
          </div>
        </section>

        <section class="reviews-card">
          <div class="reviews-head">
            <div>
              <h2>Recenzije</h2>
              <p class="reviews-subtitle">
                {totalReviews} {totalReviews === 1 ? "kafić" : "kafića"}
              </p>
            </div>

            {averageCoffee && (
              <div class="coffee-stat">
                <span class="coffee-stat-label">Prosek kafe</span>
                <strong>{averageCoffee}/10</strong>
              </div>
            )}
          </div>

          <div class="reviews-list">
            {profile.reviews.map((review) => {
              const reviewAverage = averageFromRatings(review.ratings).toFixed(1);

              return (
                <article class="review-item">
                  <div class="review-top">
                    <div>
                      <h3>{review.cafeName}</h3>
                      <p class="city">{review.city}</p>
                    </div>

                    <div class="score-box">
                      <span>Ocena</span>
                      <strong>{reviewAverage}</strong>
                    </div>
                  </div>

                  <p class="note">{review.note}</p>

                  <div class="ratings-grid">
                    <div class="rating-row">
                      <span>Kafa</span>
                      <strong>{review.ratings.coffee}/10</strong>
                    </div>

                    <div class="rating-row">
                      <span>Ambijent</span>
                      <strong>{review.ratings.ambience}/10</strong>
                    </div>

                    <div class="rating-row">
                      <span>Usluga</span>
                      <strong>{review.ratings.service}/10</strong>
                    </div>

                    <div class="rating-row">
                      <span>Cena</span>
                      <strong>{review.ratings.price}/10</strong>
                    </div>

                    <div class="rating-row">
                      <span>Ponovni dolazak</span>
                      <strong>{review.ratings.revisit}/10</strong>
                    </div>
                  </div>
                </article>
              );
            })}
          </div>
        </section>
      </div>
    </main>
  </body>
</html>

<style>
  :root {
    font-family: Arial, Helvetica, sans-serif;
    color-scheme: light;
  }

  * {
    box-sizing: border-box;
  }

  html,
  body {
    margin: 0;
    min-height: 100%;
  }

  body {
    background: #5f5f61;
    color: #111;
  }

  .page {
    position: relative;
    min-height: 100svh;
    overflow: hidden;
    padding: 2rem 1rem 3rem;
    background: linear-gradient(180deg, #6d6d70 0%, #59595c 100%);
  }

  .shape {
    position: absolute;
    pointer-events: none;
  }

  .shape-top-left {
    top: 0;
    left: 0;
    width: 44vw;
    height: 24vh;
    min-width: 170px;
    min-height: 150px;
    background: #f1f1f3;
    clip-path: polygon(0 0, 100% 0, 0 100%);
  }

  .shape-top-right {
    top: 0;
    right: 0;
    width: 42vw;
    height: 23vh;
    min-width: 150px;
    min-height: 140px;
    background: linear-gradient(135deg, #f6f6f8 0%, #d9dbe1 100%);
    clip-path: polygon(35% 0, 100% 0, 100% 60%, 72% 100%, 0 55%);
  }

  .shape-bottom-left {
    left: 0;
    bottom: 0;
    width: 22vw;
    height: 18vh;
    min-width: 90px;
    min-height: 110px;
    background: rgba(0, 0, 0, 0.18);
    clip-path: polygon(0 40%, 100% 0, 100% 100%, 0 100%);
  }

  .container {
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: 420px;
    margin: 0 auto;
  }

  .hero-card {
    padding-top: 3.75rem;
    text-align: center;
  }

  .avatar-wrap {
    width: min(66vw, 220px);
    aspect-ratio: 1 / 1;
    margin: 0 auto 1.4rem;
    padding: 8px;
    border-radius: 50%;
    background: #ffffff;
    border: 5px solid #7c7c7c;
    box-shadow: 0 14px 26px rgba(0, 0, 0, 0.24);
  }

  .avatar {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 50%;
  }

  .name {
    margin: 0;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    width: fit-content;
    max-width: 100%;
    margin-inline: auto;
    font-size: clamp(2.3rem, 10vw, 4.2rem);
    line-height: 0.9;
    letter-spacing: -0.04em;
    font-weight: 800;
    color: #ffffff;
    text-shadow: 0 8px 16px rgba(0, 0, 0, 0.32);
  }

  .pik {
    margin: 0.9rem auto 0;
    width: fit-content;
    max-width: min(84vw, 320px);
    font-size: 1.05rem;
    line-height: 1.25;
    font-weight: 700;
    color: #ffffff;
    text-align: left;
    text-shadow: 0 8px 16px rgba(0, 0, 0, 0.32);
  }

  .info-card,
  .reviews-card {
    margin-top: 1.2rem;
    padding: 1rem;
    border-radius: 22px;
    background: rgba(255, 255, 255, 0.92);
    box-shadow: 0 16px 28px rgba(0, 0, 0, 0.16);
    backdrop-filter: blur(6px);
  }

  .info-card {
    display: grid;
    gap: 0.85rem;
  }

  .info-item {
    padding-bottom: 0.75rem;
    border-bottom: 1px solid rgba(0, 0, 0, 0.08);
  }

  .info-item:last-child {
    padding-bottom: 0;
    border-bottom: none;
  }

  .label {
    display: block;
    margin-bottom: 0.22rem;
    font-size: 0.8rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #6a6a6d;
  }

  .value {
    margin: 0;
    font-size: 1rem;
    line-height: 1.35;
    color: #1d1d1f;
    font-weight: 700;
  }

  .reviews-head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }

  .reviews-head h2 {
    margin: 0;
    font-size: 1.45rem;
    color: #1d1d1f;
  }

  .reviews-subtitle {
    margin: 0.3rem 0 0;
    font-size: 0.95rem;
    color: #666;
  }

  .coffee-stat {
    min-width: 96px;
    padding: 0.65rem 0.75rem;
    border-radius: 16px;
    background: #f3f3f5;
    text-align: center;
  }

  .coffee-stat-label {
    display: block;
    margin-bottom: 0.15rem;
    font-size: 0.72rem;
    font-weight: 800;
    text-transform: uppercase;
    color: #666;
  }

  .coffee-stat strong {
    font-size: 1.1rem;
    color: #1d1d1f;
  }

  .reviews-list {
    display: grid;
    gap: 0.9rem;
  }

  .review-item {
    padding: 1rem;
    border-radius: 18px;
    background: #f8f8f9;
    border: 1px solid rgba(0, 0, 0, 0.05);
  }

  .review-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.8rem;
  }

  .review-top h3 {
    margin: 0;
    font-size: 1.1rem;
    color: #1d1d1f;
  }

  .city {
    margin: 0.2rem 0 0;
    font-size: 0.92rem;
    color: #666;
  }

  .score-box {
    flex-shrink: 0;
    min-width: 72px;
    padding: 0.55rem 0.65rem;
    border-radius: 14px;
    background: #ececef;
    text-align: center;
  }

  .score-box span {
    display: block;
    font-size: 0.72rem;
    text-transform: uppercase;
    color: #666;
    font-weight: 800;
  }

  .score-box strong {
    display: block;
    margin-top: 0.1rem;
    font-size: 1.1rem;
    color: #1d1d1f;
  }

  .note {
    margin: 0.85rem 0 0;
    font-size: 0.95rem;
    line-height: 1.45;
    color: #333;
  }

  .ratings-grid {
    display: grid;
    gap: 0.55rem;
    margin-top: 0.95rem;
  }

  .rating-row {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.65rem 0.75rem;
    border-radius: 12px;
    background: #ffffff;
    font-size: 0.93rem;
  }

  .rating-row span {
    color: #555;
    font-weight: 700;
  }

  .rating-row strong {
    color: #111;
  }

  @media (min-width: 768px) {
    .page {
      padding-top: 2.5rem;
    }

    .hero-card {
      padding-top: 2.5rem;
    }

    .avatar-wrap {
      width: 240px;
    }

    .info-card,
    .reviews-card {
      padding: 1.2rem;
    }
  }
</style>