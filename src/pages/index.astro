---
import { profiles } from "../data/profiles";
---

<html lang="sr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>PIK Profiles</title>
  </head>

  <body>
    <main class="home">
      <h1>PIK Profiles</h1>
      <p>Izaberi profil:</p>

      <ul>
        {profiles.map((profile) => (
          <li>
            <a href={`/${profile.slug}`}>
              {profile.firstName} {profile.lastName}
            </a>
          </li>
        ))}
      </ul>
    </main>
  </body>
</html>

<style>
  body {
    margin: 0;
    font-family: Arial, Helvetica, sans-serif;
    background: #f4f4f4;
    color: #222;
  }

  .home {
    min-height: 100vh;
    padding: 2rem 1.25rem;
    max-width: 700px;
    margin: 0 auto;
  }

  h1 {
    margin-bottom: 0.75rem;
  }

  ul {
    padding-left: 1.2rem;
  }

  li {
    margin-bottom: 0.75rem;
  }

  a {
    color: #111;
    font-weight: 700;
    text-decoration: none;
  }

  a:hover {
    text-decoration: underline;
  }
</style>