---
const profile = {
  firstName: "Nikola",
  lastName: "Spasojević",
  title: "☕ profesionalni ispijač kafa",
  image: "C:\\Users\\nikol\\Documents\\HTML Files\\PIK-site\\public\\nikola.jpeg",
};
---

<html lang="sr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{profile.firstName} {profile.lastName}</title>
    <meta
      name="description"
      content={`${profile.firstName} ${profile.lastName} - profilna stranica`}
    />
  </head>

  <body>
    <main class="page">
      <div class="shape shape-top-left"></div>
      <div class="shape shape-top-right"></div>
      <div class="shape shape-bottom-left"></div>

      <section class="profile">
        <div class="avatar-wrap">
          <img
            src={profile.image}
            alt={`${profile.firstName} ${profile.lastName}`}
            class="avatar"
          />
        </div>

        <div class="content">
          <h1 class="name">
            <span>{profile.firstName}</span>
            <span>{profile.lastName}</span>
          </h1>

          <p class="tagline">{profile.title}</p>
        </div>
      </section>
    </main>
  </body>
</html>

<style>
  :root {
    font-family: Inter, Arial, Helvetica, sans-serif;
  }

  * {
    box-sizing: border-box;
  }

  html,
  body {
    margin: 0;
    min-height: 100%;
  }

  body {
    background: #666;
  }

  .page {
    position: relative;
    min-height: 100vh;
    overflow: hidden;
    display: flex;
    justify-content: center;
    align-items: flex-start;
    padding: 3.5rem 1.25rem 2.5rem;
    background: linear-gradient(180deg, #7a7a7a 0%, #616161 100%);
  }

  .shape {
    position: absolute;
    pointer-events: none;
  }

  .shape-top-left {
    top: 0;
    left: 0;
    width: min(70vw, 430px);
    height: min(42vh, 330px);
    background: #f3f3f5;
    clip-path: polygon(0 0, 100% 0, 0 100%);
  }

  .shape-top-right {
    top: 0;
    right: -4vw;
    width: min(74vw, 470px);
    height: min(40vh, 320px);
    background: linear-gradient(135deg, #f8f8fa 0%, #d9dbe2 100%);
    clip-path: polygon(28% 0, 100% 0, 58% 100%, 0 64%);
  }

  .shape-bottom-left {
    left: 0;
    bottom: 0;
    width: min(34vw, 220px);
    height: min(22vh, 180px);
    background: rgba(0, 0, 0, 0.22);
    clip-path: polygon(0 35%, 100% 0, 100% 100%, 0 100%);
  }

  .profile {
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: 520px;
    padding-top: 2rem;
  }

  .avatar-wrap {
    width: min(78vw, 310px);
    aspect-ratio: 1 / 1;
    margin: 0 auto 2rem;
    padding: 10px;
    border-radius: 50%;
    background: white;
    border: 6px solid #7c7c7c;
    box-shadow: 0 12px 30px rgba(0, 0, 0, 0.22);
  }

  .avatar {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    border-radius: 50%;
  }

  .content {
    width: min(78vw, 310px);
    margin: 0 auto;
  }

  .name {
    margin: 0 0 0.9rem;
    display: flex;
    flex-direction: column;
    gap: 0;
    font-size: clamp(3rem, 9vw, 4.6rem);
    line-height: 0.9;
    letter-spacing: -0.04em;
    font-weight: 800;
    color: white;
    text-shadow: 0 10px 18px rgba(0, 0, 0, 0.32);
  }

  .tagline {
    margin: 0;
    font-size: clamp(1.2rem, 4.5vw, 1.9rem);
    font-weight: 700;
    color: white;
    text-shadow: 0 10px 18px rgba(0, 0, 0, 0.32);
  }

  @media (min-width: 700px) {
    .page {
      padding-top: 4rem;
    }

    .avatar-wrap {
      width: 320px;
    }

    .content {
      width: 320px;
    }
  }
</style>